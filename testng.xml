<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="GitHub Analytics Suite" parallel="tests" thread-count="4">

    <listeners>
        <listener class-name="listeners.RetryAnnotationTransformer"/>
        <listener class-name="listeners.FrameworkListener"/>
    </listeners>

    <test name="Java">
        <parameter name="topic" value="Java"/>
        <classes>
            <class name="tests.GitHubSearchTest"/>
            <class name="tests.RepositoryAnalyticsTest"/>
        </classes>
    </test>

    <test name="Python">
        <parameter name="topic" value="Python"/>
        <classes>
            <class name="tests.GitHubSearchTest"/>
            <class name="tests.RepositoryAnalyticsTest"/>
        </classes>
    </test>

    <test name="Selenium">
        <parameter name="topic" value="Selenium"/>
        <classes>
            <class name="tests.GitHubSearchTest"/>
            <class name="tests.RepositoryAnalyticsTest"/>
        </classes>
    </test>

    <test name="Automation">
        <parameter name="topic" value="Automation"/>
        <classes>
            <class name="tests.GitHubSearchTest"/>
            <class name="tests.RepositoryAnalyticsTest"/>
        </classes>
    </test>

</suite>
